# spnavrc - spacenavd configuration
# Optimized for 3Dconnexion SpaceNavigator / SpaceMouse Compact

# Global sensitivity (default: 1.0, range: 0.1 - 10.0)
sensitivity = 0.7

# Per-axis sensitivity (translation)
sensitivity-translation-x = 1.0
sensitivity-translation-y = 1.0
sensitivity-translation-z = 1.0

# Per-axis sensitivity (rotation)
sensitivity-rotation-x = 1.0
sensitivity-rotation-y = 1.0
sensitivity-rotation-z = 1.0

# Dead zone (0-100, percentage of axis range)
dead-zone = 10

# Axis inversion. spacenavd takes a single string per group naming the
# axes to invert (any combination of x, y, z). Default is no inversion,
# which is what we want — uncomment + adjust if your hardware orientation
# needs flipping. The older per-axis 'invert-rot-x = 0/1' syntax is not
# recognized by spacenavd 1.3.1 and silently ignored.
#invert-rot = yz
#invert-trans = yz

# Swap Y/Z axes (0=no, 1=yes)
swap-yz = 0

# LED control (0=off, 1=on, 2=auto)
led = 2

# Device grab. MUST be 0 for this stack: spacemouse-desktop reads the
# kernel input device directly (bypasses spacenavd), so spacenavd must
# not hold the device exclusively. With grab=0 both can read events.
grab = 0

# Repeat interval in ms (0=disabled)
repeat-interval = 0
