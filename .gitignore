# Compiled binaries (Linux ELFs have no extension, so the daemon
# targets must be listed explicitly; the CI no-binaries job catches
# anything else that slips past these patterns)
src/spacemouse-desktop
src/spacemouse-test
src/spnav_example
src/tests/test_curve
src/tests/test_key_lookup
src/tests/test_de_detect
src/tests/test_scroll_acc
src/tests/test_kinput_state
src/tests/test_command_socket

# pytest cache
.pytest_cache/

# Generic compiled artefacts (mostly defensive — none of these should
# ever be produced by this project, but a stray one shouldn't slip in)
*.o
*.a
*.so
*.so.*
*.dylib
*.dll
*.exe

# Python
__pycache__/
*.pyc
*.pyo

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Local notes
CLAUDE.md
.claude/
private/

# Dev tools
docs/take_screenshots.py

# FreeCAD build artifacts (source trees, compiled objects)
freecad-build/
freecad/pacman-build/src/
freecad/pacman-build/pkg/
freecad/pacman-build/freecad/
freecad/pacman-build/*.pkg.tar.zst
freecad/pacman-build/*.log

# OS
.DS_Store
Thumbs.db
